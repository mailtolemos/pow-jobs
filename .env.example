# ─── PoW Jobs environment variables ─────────────────────────────────────────
# Copy this file to `.env.local` and fill in the values.
#
# Only DATABASE_URL and AUTH_SECRET are strictly required for auth to work.
# Everything else has a sensible dev-mode fallback or is optional.

# ─── Database (required) ────────────────────────────────────────────────────
# Neon Postgres connection string (pooled or direct — pooled is fine).
# Get one free at https://neon.tech (project → Dashboard → Connection Details).
# Format: postgresql://user:pass@host/db?sslmode=require
DATABASE_URL=

# ─── Auth (required) ────────────────────────────────────────────────────────
# Secret used to sign session JWTs. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
# Must be stable across deploys (changing it logs everyone out).
AUTH_SECRET=

# Public URL of this app (used in magic-link emails and Telegram deep-links).
# Local dev: http://localhost:3000 ;  prod: https://pow-jobs.vercel.app
APP_URL=http://localhost:3000

# ─── Email (magic-link + job digests) ───────────────────────────────────────
# Resend API key. Get one free at https://resend.com.
# If unset, magic-link URLs are logged to the server console and returned in
# the /api/auth/signin response so you can click through in dev.
RESEND_API_KEY=

# From-address for all outgoing mail. Must be a verified domain in Resend,
# OR "onboarding@resend.dev" for the first 100 dev emails.
EMAIL_FROM=PoW Jobs <onboarding@resend.dev>

# ─── Cron (alert dispatch) ──────────────────────────────────────────────────
# Shared secret for /api/cron/alerts when invoked outside Vercel Cron.
# Vercel Cron sets `x-vercel-cron` and bypasses this. For manual/curl runs:
#   curl -H "Authorization: Bearer $CRON_SECRET" https://.../api/cron/alerts
# If unset in dev/preview, the endpoint is open.
CRON_SECRET=

# ─── Telegram bot (optional — enables Telegram alerts) ──────────────────────
# Create a bot by messaging @BotFather on Telegram → /newbot → copy the token.
TELEGRAM_BOT_TOKEN=

# Webhook secret. Telegram stamps this on every incoming update so we can
# verify the request really came from Telegram. Generate with:
#   node -e "console.log(require('crypto').randomBytes(24).toString('base64url'))"
# Then register the webhook once:
#   curl "https://api.telegram.org/bot$TELEGRAM_BOT_TOKEN/setWebhook?url=$APP_URL/api/telegram/webhook&secret_token=$TELEGRAM_WEBHOOK_SECRET"
TELEGRAM_WEBHOOK_SECRET=

# Public username of your bot (no @). Used to build the t.me/<bot>?start=<token>
# deep-link on the Profile → Alerts page. e.g. "powjobs_bot"
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=

# ─── LLM (optional — Claude as match judge + LinkedIn paste importer) ───────
# If unset, matching uses structured scoring only and LinkedIn import falls
# back to regex heuristics. Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Claude model. Default: claude-sonnet-4-6
CLAUDE_MODEL=claude-sonnet-4-6
