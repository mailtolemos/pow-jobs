# PoW Jobs environment variables

# Optional: Claude API key for LLM-as-judge match scoring.
# If unset, the prototype uses a deterministic heuristic scorer instead.
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Claude model. Default: claude-sonnet-4-6
CLAUDE_MODEL=claude-sonnet-4-6

# Path to the SQLite database file. Default: ./data/pow-jobs.db
DATABASE_PATH=./data/pow-jobs.db
