{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/cron/alerts?frequency=daily",
      "schedule": "0 14 * * *"
    },
    {
      "path": "/api/cron/alerts?frequency=weekly",
      "schedule": "0 14 * * 1"
    },
    {
      "path": "/api/cron/ingest",
      "schedule": "0 6 * * *"
    }
  ]
}
